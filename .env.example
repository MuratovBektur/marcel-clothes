DB_USER = YOUR_DB_USER
DB_PASSWORD = YOUR_DB_PASSWORD
DB_NAME = YOUR_DB_NAME
DB_PORT = YOUR_DB_PORT
DB_HOST = YOUR_DB_HOST # используй host.docker.internal если бд запущен на хосте

TELEGRAM_BOT_TOKEN = YOUR_TELEGRAM_BOT_TOKEN

# Список номеров телефонов с доступом к боту (через запятую, любой формат)
ALLOWED_PHONES = +79001234567,+79009876543

# Публичный домен этого сайта — используется для построения ссылок на фото товаров
PUBLIC_URL = https://marcel.kg

# Синхронизация товаров с глобальным маркетом (showroom / optom.store)
SHOWROOM_API_URL = https://optom.store/api/bot-products
SHOWROOM_API_KEY = YOUR_SHOWROOM_API_KEY